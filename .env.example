# Copy to .env.local and adjust. See docs/keycloak-browser.md
#
# Keycloak client (public): Standard flow + PKCE; Valid redirect URIs e.g.
#   http://localhost:3000/*
#   http://localhost:3000/auth/callback
# Web origins: http://localhost:3000

# Public app URL (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Issuer = JWT iss (realm)
NEXT_PUBLIC_KEYCLOAK_ISSUER=http://localhost:8090/realms/your-realm

# Client id (must match a public OIDC client in that realm)
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=internal-comm-web
